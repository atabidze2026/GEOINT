# Server environment variables (copy to .env locally or set in hosting)
# Admin credentials used by /api/admin/login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password
ADMIN_TOKEN=admin123-token

# Server port (optional)
PORT=3001

# Database URL for production (if using Postgres/Mongo). For local sqlite, leave empty.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# If your frontend uses Vite and needs a base API url at build-time, set in client Vite env
# Example (set in Vercel as VITE_API_BASE):
# VITE_API_BASE=https://your-backend.example.com
